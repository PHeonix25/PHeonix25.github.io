---
const year = new Date().getFullYear();

const links = [
  { href: 'https://linkedin.com/in/pathermens', label: 'LinkedIn' },
  { href: 'https://github.com/PHeonix25', label: 'GitHub' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/feed.xml', label: 'RSS' },
];
---

<footer>
  <div class="footer-logo">Pat<span>.</span>Hermens</div>

  <ul role="list">
    {links.map(link => (
      <li><a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.label}</a></li>
    ))}
  </ul>

  <p class="footer-copy">&copy; {year} Pat Hermens. Built with Astro.</p>
</footer>

<style>
  footer {
    padding: 2.5rem 3rem;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--grey-3);
  }
  .footer-logo span { color: var(--accent); }

  ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    flex-wrap: wrap;
  }

  a {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-3);
    text-decoration: none;
    transition: color 0.2s;
  }
  a:hover { color: var(--white); }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--grey-2);
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    footer {
      padding: 2rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
