---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category: string;
  tags?: string[];
  readingTime?: number;
}

const { title, description, date, category, tags = [], readingTime = 5 } = Astro.props;

const formattedDate = date.toLocaleDateString('en-AU', {
  day: '2-digit', month: 'long', year: 'numeric'
});

const catClass = {
  engineering: 'cat-eng',
  leadership:  'cat-lead',
  speaking:    'cat-speak',
  personal:    'cat-per',
  books:       'cat-book',
}[category] ?? 'cat-eng';
const catLabel = category.charAt(0).toUpperCase() + category.slice(1);
---

<BaseLayout title={`${title} - Pat Hermens`} description={description}>
  <article class="article">

    <!-- Header -->
    <header class="article-header">
      <div class="article-header-inner">
        <span class={`post-cat ${catClass}`}>{catLabel}</span>
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-subtitle">{description}</p>}
        <div class="article-byline">
          <span>Pat Hermens</span>
          <span class="sep">·</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="sep">·</span>
          <span>{readingTime} min read</span>
          {tags.length > 0 && (
            <>
              <span class="sep">·</span>
              <span class="byline-tags">
                {tags.map(tag => <span class="inline-tag">#{tag}</span>)}
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Body + TOC -->
    <div class="article-body-wrap">
      <!-- Left gutter (decorative) -->
      <div></div>

      <!-- Prose -->
      <div class="prose" id="article-content">
        <slot />
      </div>

      <!-- TOC sidebar -->
      <aside class="toc-sidebar" aria-label="Table of contents">
        <div class="toc" id="toc">
          <p class="toc-label">Contents</p>
          <ul id="toc-list" role="list">
            <!-- Populated by JS -->
          </ul>
        </div>
      </aside>
    </div>

    <!-- Post footer -->
    <footer class="article-footer">
      <a href="/writing" class="back-link">← All posts</a>
      {tags.length > 0 && (
        <div class="footer-tags">
          {tags.map(tag => <span class="inline-tag">#{tag}</span>)}
        </div>
      )}
    </footer>

  </article>
</BaseLayout>

<style>
  .article {
    max-width: var(--max-wide);
    margin: 0 auto;
  }

  /* ─── Header ──────────────────────── */
  .article-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr minmax(0, var(--max-prose)) 280px;
    gap: 0;
  }

  .article-header-inner {
    grid-column: 2;
    padding: 0 2rem;
  }

  .post-cat {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    margin-bottom: 1.5rem;
    border: 1px solid;
    width: fit-content;
  }

  .article-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.0;
    letter-spacing: -0.015em;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .article-subtitle {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--grey-4);
    margin-bottom: 2rem;
    line-height: 1.55;
    max-width: 54ch;
  }

  .article-byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--grey-3);
    letter-spacing: 0.08em;
  }

  .sep { color: var(--grey-2); }

  .byline-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .inline-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--grey-3);
    letter-spacing: 0.06em;
    transition: color 0.18s;
  }
  .inline-tag:hover { color: var(--accent); }

  /* ─── Body layout ──────────────────── */
  .article-body-wrap {
    display: grid;
    grid-template-columns: 1fr minmax(0, var(--max-prose)) 280px;
    gap: 0;
    padding: 3rem 0;
  }

  .prose {
    grid-column: 2;
    padding: 0 2rem;
  }

  .toc-sidebar {
    padding: 0 2rem;
    min-width: 0;
  }

  /* ─── TOC ──────────────────────────── */
  .toc {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .toc-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--grey-3);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .toc-label::before {
    content: '';
    display: block;
    width: 16px; height: 1px;
    background: var(--grey-3);
  }

  #toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* TOC items injected by JS */
  :global(.toc-item) {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--grey-3);
    padding: 0.3rem 0.75rem;
    border-left: 2px solid var(--line);
    cursor: pointer;
    transition: all 0.18s;
    line-height: 1.4;
    text-decoration: none;
    display: block;
  }
  :global(.toc-item:hover) {
    color: var(--white);
    border-left-color: var(--accent);
  }
  :global(.toc-item.active) {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  :global(.toc-item-h3) {
    padding-left: 1.5rem;
    font-size: 0.58rem;
  }

  /* ─── Prose styles ─────────────────── */
  .prose :global(p) {
    font-size: 1.05rem;
    line-height: 1.82;
    color: var(--grey-5);
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  /* Drop cap on first paragraph */
  .prose :global(p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-size: 4.2rem;
    font-weight: 900;
    line-height: 0.75;
    float: left;
    margin-right: 0.1em;
    margin-top: 0.08em;
    color: var(--accent);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.65rem;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--white);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--grey-5);
    font-size: 1rem;
    line-height: 1.75;
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent2);
    padding: 1rem 1.5rem;
    background: rgba(255, 122, 61, 0.07);
    margin: 1.75rem 0;
    font-style: italic;
    color: var(--grey-4);
    font-size: 0.95rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(0, 212, 212, 0.3);
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .prose :global(strong) {
    color: var(--white);
    font-weight: 500;
  }

  .prose :global(em) { font-style: italic; }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border: 1px solid var(--line);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.75rem 0;
    font-family: var(--font-mono);
  }
  .prose :global(th) {
    background: var(--grey-1);
    color: var(--white);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.6rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--accent);
  }
  .prose :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--grey-4);
  }
  .prose :global(tr:hover td) { background: var(--grey-1); }

  /* ─── Article footer ───────────────── */
  .article-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 2rem;
    margin: 0 auto;
    max-width: calc(var(--max-prose) + 4rem);
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-3);
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent); }

  .footer-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  /* ─── Responsive ───────────────────── */
  @media (max-width: 1100px) {
    .article-header,
    .article-body-wrap {
      grid-template-columns: 2rem 1fr 2rem;
    }
    .toc-sidebar { display: none; }
    .article-header-inner { padding: 0 1.5rem; }
    .prose { padding: 0 1.5rem; }
  }

  @media (max-width: 600px) {
    .article-header,
    .article-body-wrap {
      grid-template-columns: 1rem 1fr 1rem;
    }
    .article-title { font-size: 2.2rem; }
    .article-header-inner,
    .prose { padding: 0 1rem; }
  }
</style>

<script>
  // Build TOC from headings
  const headings = document.querySelectorAll<HTMLElement>('#article-content h2, #article-content h3');
  const tocList = document.getElementById('toc-list');

  if (headings.length > 0 && tocList) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      a.className = `toc-item ${h.tagName === 'H3' ? 'toc-item-h3' : ''}`;
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Scrollspy
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          const id = entry.target.getAttribute('id');
          const link = tocList.querySelector(`[href="#${id}"]`);
          if (entry.isIntersecting) {
            tocList.querySelectorAll('.toc-item').forEach(el => el.classList.remove('active'));
            link?.classList.add('active');
          }
        });
      },
      { rootMargin: `-${56 + 32}px 0px -60% 0px` }
    );
    headings.forEach(h => observer.observe(h));
  }
</script>
