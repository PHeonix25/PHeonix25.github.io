---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Pat Hermens">
  <div class="not-found">
    <div class="not-found-inner">
      <p class="eyebrow">Error</p>
      <h1 class="code">404</h1>
      <p class="message">This page doesn't exist. Maybe it was moved, or maybe it never did.</p>
      <a href="/" class="btn">← Back home</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
  }
  .not-found-inner { text-align: center; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 1rem;
  }

  .code {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(6rem, 20vw, 14rem);
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 2px var(--grey-2);
    margin-bottom: 1.5rem;
  }

  .message {
    font-size: 1rem;
    color: var(--grey-4);
    margin-bottom: 2rem;
    max-width: 36ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.75rem 1.75rem;
    transition: all 0.2s;
    display: inline-block;
  }
  .btn:hover { background: transparent; color: var(--accent); }
</style>
