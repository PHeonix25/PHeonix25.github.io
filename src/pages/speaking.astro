---
import BaseLayout from '../layouts/BaseLayout.astro';

type Talk = {
  date: string;
  event: string;
  eventUrl?: string;
  location: string;
  title: string;
  titleUrl?: string;
  links?: { label: string; url: string }[];
  note?: string;
};

const talks: Talk[] = [
  {
    date: '2019-06-06',
    event: 'Bloemert TechEvent',
    location: 'Slaghorst, NL',
    title: 'Culture, DevOps, and an AMA',
  },
  {
    date: '2019-05-16',
    event: '4DotNet Developer Days',
    eventUrl: 'https://events.4dotnet.nl/move-up-with-high-performance-architecture/',
    location: 'Meppel, NL',
    title: 'Keynote — Finding the Second Story',
    titleUrl: 'https://speakerdeck.com/pheonix25/finding-the-second-story-learning-from-failure',
  },
  {
    date: '2019-04-02',
    event: 'CodeMotion Amsterdam',
    eventUrl: 'https://events.codemotion.com/conferences/amsterdam/2019/',
    location: 'Amsterdam, NL',
    title: 'From 100, to 1000+ deployments a day',
    titleUrl: 'https://speakerdeck.com/pheonix25/from-100-to-1000-plus-deployments-a-day-codemotion-edition',
  },
  {
    date: '2019-03-13',
    event: 'FutureTech',
    eventUrl: 'https://futuretech.nl/sessions/from-developer-to-development-manager/',
    location: 'Utrecht, NL',
    title: 'From Developer, to Development Manager',
    links: [
      { label: 'Slides', url: 'https://speakerdeck.com/pheonix25/from-developer-to-development-manager-futuretech-edition' },
    ],
  },
  {
    date: '2018-12-14',
    event: 'SDN event, December 2018',
    eventUrl: 'https://www.sdn.nl/EVENTS/14-december-2018',
    location: 'Zeist, NL',
    title: 'From Developer to Development Manager',
    links: [
      { label: 'Slides', url: 'https://speakerdeck.com/pheonix25/from-developer-to-development-manager-sdn-editie' },
      { label: 'Video', url: 'https://www.youtube.com/watch?v=gXsP8cydEgY' },
    ],
  },
  {
    date: '2018-12-12',
    event: 'NISI Continuous Delivery 3.0',
    eventUrl: 'https://nisi.nl/cd30-cursus-in-het-kort',
    location: 'Utrecht University, NL',
    title: 'Guest Lecturer',
  },
  {
    date: '2018-11-22',
    event: 'DevTalksJnr',
    eventUrl: 'http://www.devtalks.ro/bucharest/devtalksjr/',
    location: 'Bucharest, Romania',
    title: 'From Developer to Development Manager',
    titleUrl: 'https://speakerdeck.com/pheonix25/from-developer-to-development-manager',
  },
  {
    date: '2018-10-18',
    event: 'PowerShell Conference Asia 2018',
    eventUrl: 'http://psconf.asia',
    location: 'Singapore',
    title: 'From 100 to 1,000+ deployments a day!',
    links: [
      { label: 'Slides', url: 'https://speakerdeck.com/pheonix25/from-100-to-1000-plus-deployments-a-day-psconfasia-edition' },
      { label: 'Video', url: 'https://livestream.com/gaelcolas/PSConfAsia/videos/182072584' },
    ],
    note: 'Plus a second session: "Creating a complete pipeline in as few questions as possible"',
  },
  {
    date: '2018-10-01',
    event: 'Techorama NL',
    eventUrl: 'https://techorama.nl',
    location: 'CineMec Ede, NL',
    title: 'From 100 to 1,000+ deployments a day!',
    titleUrl: 'https://speakerdeck.com/pheonix25/from-100-to-1000-plus-deployments-a-day-techoramanl-editie',
  },
  {
    date: '2018-06-15',
    event: 'SDN event, June 2018',
    eventUrl: 'https://www.sdn.nl/EVENTS/15-juni-2018',
    location: 'Zeist, NL',
    title: 'A Coolblue CI/CD Story',
    links: [
      { label: 'Slides', url: 'https://speakerdeck.com/pheonix25/cd-story' },
      { label: 'Video', url: 'https://youtu.be/_RrFmdjt1-A' },
    ],
  },
  {
    date: '2018-05-23',
    event: 'Techorama BE',
    eventUrl: 'https://techoramabelgium2018.sched.com/event/DjAe',
    location: 'Antwerp, BE',
    title: 'From 100 to 1,000+ deployments a day!',
    titleUrl: 'https://speakerdeck.com/pheonix25/from-100-to-1-000-plus-deployments-a-day-techorama-edition',
  },
  {
    date: '2017-10-12',
    event: 'TechDays Netherlands',
    eventUrl: 'https://www.techdays.nl/Sessies/',
    location: 'Amsterdam, NL',
